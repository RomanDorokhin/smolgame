{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SmolGame Data-Driven Game Configuration",
  "description": "Comprehensive JSON schema for configuring a SmolGame, to be used with a Golden Seed and Smart Injector.",
  "type": "object",
  "required": [
    "gameId",
    "gameTitle",
    "gameDescription",
    "gameType",
    "player",
    "world",
    "mechanics",
    "visuals",
    "audio",
    "difficulty",
    "social"
  ],
  "properties": {
    "gameId": {
      "type": "string",
      "description": "Unique identifier for the game."
    },
    "gameTitle": {
      "type": "string",
      "description": "Title of the game."
    },
    "gameDescription": {
      "type": "string",
      "description": "Brief description of the game."
    },
    "gameType": {
      "type": "string",
      "enum": ["runner", "platformer", "puzzle", "shooter", "rpg", "other"],
      "description": "Primary genre or type of the game."
    },
    "player": {
      "type": "object",
      "description": "Configuration for the player character.",
      "required": ["size", "color", "speed", "jumpHeight", "doubleJumpEnabled"],
      "properties": {
        "size": { "type": "number", "minimum": 10, "maximum": 100 },
        "color": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
        "speed": { "type": "number", "minimum": 1, "maximum": 20 },
        "jumpHeight": { "type": "number", "minimum": 5, "maximum": 20 },
        "doubleJumpEnabled": { "type": "boolean" },
        "trailColor": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
        "animationFrames": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "description": "URLs for player animation frames (e.g., run, jump).
        }
      }
    },
    "world": {
      "type": "object",
      "description": "Configuration for the game world and environment.",
      "required": ["groundY", "backgroundColor", "obstacleTypes", "collectibleTypes"],
      "properties": {
        "groundY": { "type": "number", "minimum": 0.5, "maximum": 0.9, "description": "Ground position as a percentage of canvas height." },
        "backgroundColor": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
        "obstacleTypes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "color", "width", "height", "speedMultiplier", "spawnWeight"],
            "properties": {
              "id": { "type": "string" },
              "color": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
              "width": { "type": "number", "minimum": 20, "maximum": 150 },
              "height": { "type": "number", "minimum": 20, "maximum": 150 },
              "speedMultiplier": { "type": "number", "minimum": 0.5, "maximum": 2.0 },
              "spawnWeight": { "type": "number", "minimum": 0, "maximum": 100 },
              "assetUrl": { "type": "string", "format": "uri", "description": "URL for obstacle sprite/image." }
            }
          }
        },
        "collectibleTypes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "color", "radius", "scoreValue", "spawnWeight"],
            "properties": {
              "id": { "type": "string" },
              "color": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
              "radius": { "type": "number", "minimum": 5, "maximum": 30 },
              "scoreValue": { "type": "number", "minimum": 1, "maximum": 100 },
              "spawnWeight": { "type": "number", "minimum": 0, "maximum": 100 },
              "assetUrl": { "type": "string", "format": "uri", "description": "URL for collectible sprite/image." }
            }
          }
        }
      }
    },
    "mechanics": {
      "type": "object",
      "description": "Core game mechanics and logic hooks.",
      "properties": {
        "gameOverCondition": { "type": "string", "description": "JavaScript snippet for game over condition." },
        "onPlayerHit": { "type": "string", "description": "JavaScript snippet to execute when player hits an obstacle." },
        "onCollectibleCollected": { "type": "string", "description": "JavaScript snippet to execute when collectible is collected." },
        "customUpdateLogic": { "type": "string", "description": "Optional custom update logic snippet." }
      }
    },
    "visuals": {
      "type": "object",
      "description": "Visual effects and rendering configuration.",
      "required": ["parallaxLayers", "postProcessing"],
      "properties": {
        "parallaxLayers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["assetUrl", "speed", "yOffset", "alpha"],
            "properties": {
              "assetUrl": { "type": "string", "format": "uri", "description": "URL for parallax layer image." },
              "speed": { "type": "number", "minimum": 0.01, "maximum": 1.0 },
              "yOffset": { "type": "number", "minimum": -200, "maximum": 200 },
              "alpha": { "type": "number", "minimum": 0.1, "maximum": 1.0 }
            }
          }
        },
        "postProcessing": {
          "type": "object",
          "properties": {
            "vignetteEnabled": { "type": "boolean" },
            "scanlinesEnabled": { "type": "boolean" },
            "glowEnabled": { "type": "boolean" }
          }
        },
        "hudFont": { "type": "string", "description": "Font family for HUD elements." },
        "hudColor": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" },
        "hudGlowColor": { "type": "string", "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$" }
      }
    },
    "audio": {
      "type": "object",
      "description": "Audio configuration for SFX and music.",
      "required": ["sfx", "music"],
      "properties": {
        "sfx": {
          "type": "object",
          "patternProperties": {
            "^[a-zA-Z0-9_]+$": {
              "type": "object",
              "required": ["type", "freq", "duration"],
              "properties": {
                "type": { "type": "string", "enum": ["sine", "square", "sawtooth", "triangle"] },
                "freq": { "type": "number", "minimum": 20, "maximum": 20000 },
                "duration": { "type": "number", "minimum": 0.01, "maximum": 2.0 },
                "sweep": { "type": "number", "minimum": 0, "maximum": 20000 },
                "assetUrl": { "type": "string", "format": "uri", "description": "URL for custom SFX audio file." }
              }
            }
          }
        },
        "music": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["assetUrl", "loop", "volume"],
            "properties": {
              "assetUrl": { "type": "string", "format": "uri", "description": "URL for background music audio file." },
              "loop": { "type": "boolean" },
              "volume": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
            }
          }
        }
      }
    },
    "difficulty": {
      "type": "object",
      "description": "Dynamic difficulty scaling configuration.",
      "required": ["curve"],
      "properties": {
        "curve": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["scoreThreshold", "gameSpeed", "obstacleSpawnInterval", "collectibleSpawnInterval"],
            "properties": {
              "scoreThreshold": { "type": "number", "minimum": 0 },
              "gameSpeed": { "type": "number", "minimum": 1, "maximum": 20 },
              "obstacleSpawnInterval": { "type": "number", "minimum": 100, "maximum": 5000 },
              "collectibleSpawnInterval": { "type": "number", "minimum": 100, "maximum": 5000 }
            }
          }
        },
        "maxGameSpeed": { "type": "number", "minimum": 10, "maximum": 50 }
      }
    },
    "social": {
      "type": "object",
      "description": "Social integration features.",
      "properties": {
        "leaderboardEnabled": { "type": "boolean" },
        "shareMessage": { "type": "string" },
        "inviteMessage": { "type": "string" }
      }
    }
  }
}
