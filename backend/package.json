{
  "name": "smolgame-backend",
  "version": "0.1.0",
  "private": true,
  "description": "SmolGame API on Cloudflare Workers + D1",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create smolgame",
    "db:migrate:local": "wrangler d1 execute smolgame --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute smolgame --remote --file=./schema.sql",
    "db:migrate:remote:game-columns": "wrangler d1 execute smolgame --remote --file=./migrations/0001_add_game_columns.sql",
    "db:migrate:remote:oauth": "wrangler d1 execute smolgame --remote --file=./migrations/0002_oauth_states.sql",
    "db:migrate:remote:github-token": "wrangler d1 execute smolgame --remote --file=./migrations/0003_github_access_token.sql"
  },
  "devDependencies": {
    "wrangler": "^3.90.0"
  }
}
