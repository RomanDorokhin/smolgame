{
  "name": "smolgame-backend",
  "version": "0.1.0",
  "private": true,
  "description": "SmolGame API on Cloudflare Workers + D1",
  "type": "module",
  "scripts": {
    "start": "node src/node-server.js",
    "dev": "npx wrangler dev",
    "deploy": "npx wrangler deploy",
    "db:create": "npx wrangler d1 create smolgame",
    "db:migrate:local": "npx wrangler d1 execute smolgame --local --file=./schema.sql",
    "db:migrate:remote": "npx wrangler d1 execute smolgame --remote --file=./schema.sql",
    "db:migrate:remote:game-columns": "npx wrangler d1 execute smolgame --remote --file=./migrations/0001_add_game_columns.sql",
    "db:migrate:remote:oauth": "npx wrangler d1 execute smolgame --remote --file=./migrations/0002_oauth_states.sql",
    "db:migrate:remote:github-token": "npx wrangler d1 execute smolgame --remote --file=./migrations/0003_github_access_token.sql",
    "db:migrate:remote:github-user-columns": "npx wrangler d1 execute smolgame --remote --file=./migrations/0004_github_user_columns.sql",
    "db:migrate:remote:user-game-plays": "npx wrangler d1 execute smolgame --remote --file=./migrations/0005_user_game_plays.sql",
    "db:migrate:remote:github-user-id-not-unique": "npx wrangler d1 execute smolgame --remote --file=./migrations/0006_github_user_id_drop_unique_index.sql",
    "db:migrate:remote:display-name": "npx wrangler d1 execute smolgame --remote --file=./migrations/0007_users_display_name.sql",
    "db:migrate:remote:bio": "npx wrangler d1 execute smolgame --remote --file=./migrations/0008_users_bio.sql",
    "db:migrate:remote:dob-consent": "npx wrangler d1 execute smolgame --remote --file=./migrations/0009_users_dob_consent.sql",
    "db:migrate:remote:reviews": "npx wrangler d1 execute smolgame --remote --file=./migrations/0010_game_reviews.sql",
    "db:migrate:remote:multi-reviews": "npx wrangler d1 execute smolgame --remote --file=./migrations/0011_allow_multi_reviews.sql",
    "db:migrate:remote:multi-reviews-reply": "npx wrangler d1 execute smolgame --remote --file=./migrations/0012_review_system_upgrade.sql"
  },
  "dependencies": {
    "acorn": "^8.16.0",
    "acorn-walk": "^8.3.5",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.5",
    "escodegen": "^2.1.0"
  },
  "devDependencies": {
    "wrangler": "^4.86.0"
  }
}
