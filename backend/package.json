{
  "name": "smolgame-backend",
  "version": "0.1.0",
  "private": true,
  "description": "SmolGame API on Cloudflare Workers + D1",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create smolgame",
    "db:migrate:local": "wrangler d1 execute smolgame --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute smolgame --remote --file=./schema.sql",
    "db:migrate:remote:game-columns": "wrangler d1 execute smolgame --remote --file=./migrations/0001_add_game_columns.sql",
    "db:migrate:remote:oauth": "wrangler d1 execute smolgame --remote --file=./migrations/0002_oauth_states.sql",
    "db:migrate:remote:github-token": "wrangler d1 execute smolgame --remote --file=./migrations/0003_github_access_token.sql",
    "db:migrate:remote:github-user-columns": "wrangler d1 execute smolgame --remote --file=./migrations/0004_github_user_columns.sql",
    "db:migrate:remote:user-game-plays": "wrangler d1 execute smolgame --remote --file=./migrations/0005_user_game_plays.sql",
    "db:migrate:remote:github-user-id-not-unique": "wrangler d1 execute smolgame --remote --file=./migrations/0006_github_user_id_drop_unique_index.sql",
    "db:migrate:remote:display-name": "wrangler d1 execute smolgame --remote --file=./migrations/0007_users_display_name.sql",
    "db:migrate:remote:bio": "wrangler d1 execute smolgame --remote --file=./migrations/0008_users_bio.sql",
    "db:migrate:remote:dob-consent": "wrangler d1 execute smolgame --remote --file=./migrations/0009_users_dob_consent.sql"
  },
  "devDependencies": {
    "wrangler": "^3.90.0"
  }
}
