# Скопируй в backend/.dev.vars (файл в .gitignore) для локального wrangler dev.
# Для продакшена те же имена — в Cloudflare Dashboard → Worker → Variables / Secrets.

# GitHub OAuth App → Client ID (публичный)
GITHUB_CLIENT_ID=

# GitHub OAuth App → Client secrets → Generate (только secret)
GITHUB_CLIENT_SECRET=

# Опционально: если callback должен быть не origin из браузера, а всегда Worker:
# GITHUB_OAUTH_REDIRECT_BASE=https://smolgame.dorokhin731.workers.dev
